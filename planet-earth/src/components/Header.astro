---
import ActionButtons from './Button.jsx';

import { content } from '../components/languages';
const t = content.EN;
---

<header>
  <nav class="nav-container">
    <a href="/portfolio/" class="logo">PALOMA<span>.DATA</span></a>

    <div class="nav-right">
      <ul class="nav-links">
        <li><a href="/portfolio/" data-key="navHome">{t.navHome}</a></li>
        <li><a href="/portfolio/quests/" data-key="navQuests">{t.navQuests}</a></li>
        <li><a href="/portfolio/skills/" data-key="navSkills">{t.navSkills}</a></li>
      </ul>
      
      <div class="divider"></div>
      
      <ActionButtons client:load />
    </div>
  </nav>
</header>

<style>
  header {
    background-color: var(--bg);
    border-bottom: 1px solid var(--border);
    padding: 0 1rem; /* Reduced from 2rem */
    height: 60px;
    display: flex;
    align-items: center;
    position: sticky;
    top: 0;
    z-index: 1000;
  }

  .nav-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    /* Increase this to 1400px or use 100% to fill the screen */
    max-width: 1400px; 
    margin: 0 auto;
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .nav-links {
    display: flex;
    list-style: none;
    gap: 1.5rem;
    margin: 0;
    padding: 0;
  }

  .nav-links a {
    text-decoration: none;
    color: var(--text);
    font-weight: 500;
    font-size: 0.9rem;
  }

  .divider {
    width: 1px;
    height: 24px;
    background-color: var(--border);
  }

  .logo {
    font-weight: bold;
    font-size: 1.2rem;
    text-decoration: none;
    color: var(--text);
  }

  .logo span {
    color: var(--accent);
  }
</style>