---
import '../styles/sidebar.css';
const { content, lang = "EN" } = Astro.props;
const t = content[lang];
---

<aside class="sidebar">
  <div class="profile-card">
    <div class="photo-placeholder">
      <img 
        src="/profile-picture.JPG"
        alt="Paloma Guth Kronbauer" 
        class="profile-img"
      />
    </div>
    <h1 class="character-name">Backend | Data Engineering</h1>
    <p class="character-class"><span data-key="lvl">{t.lvl}</span> 12 </p>

    <div class="social-links">
      <a href="https://github.com/paloma-guth" target="_blank" aria-label="GitHub"><i class="fa-brands fa-github"></i></a>
      <a href="https://www.linkedin.com/in/paloma-guth-..." target="_blank" aria-label="LinkedIn"><i class="fa-brands fa-linkedin"></i></a>
    </div>

    <div class="attributes-section">
      <h4 class="attribute-title">
        <span data-key="attributesTitle">{t.attributesTitle}</span>
      </h4>
      <ul class="stats-list">
        <li><span data-key="attr1">{t.attr1}</span> <span class="stat-value">16</span></li>
        <li><span data-key="attr2">{t.attr2}</span> <span class="stat-value">14</span></li>
        <li><span data-key="attr3">{t.attr3}</span> <span class="stat-value">12</span></li>
        <li><span data-key="attr4">{t.attr4}</span> <span class="stat-value">12</span></li>
      </ul>
    </div>

    <div class="skills-section">
      <h4 class="attribute-title">
        <span data-key="skills">{t.skills}</span>
      </h4>
      
      <div class="skill-item">
        <span class="skill-name">Python</span>
        <div class="spell-levels">
          <span class="orb filled"></span><span class="orb filled"></span><span class="orb filled"></span><span class="orb filled"></span><span class="orb filled"></span>
        </div>
      </div>
      
      <div class="skill-item">
        <span class="skill-name">Linux & C</span>
        <div class="spell-levels">
          <span class="orb filled"></span><span class="orb filled"></span><span class="orb filled"></span><span class="orb filled"></span><span class="orb"></span>
        </div>
      </div>

      <div class="skill-item">
        <span class="skill-name">SQL</span>
        <div class="spell-levels">
          <span class="orb filled"></span><span class="orb filled"></span><span class="orb filled"></span><span class="orb"></span><span class="orb"></span>
        </div>
      </div>

      <a href="/portfolio/skills/" class="spellbook-btn">
        <span data-key="spellBookBtn">{t.spellBookBtn}</span>
      </a>
    </div>

    <div class="attributes-section">
      <h4 class="attribute-title">
        <span data-key="tongues">{t.tongues}</span>
      </h4>
      <ul class="language-list">
        <li>
          <span data-key="langPort">{t.langPort}</span> 
          <span class="lang-badge native" data-key="native">{t.native}</span>
        </li>
        <li>
          <span data-key="langEng">{t.langEng}</span> 
          <span class="lang-badge fluent" data-key="fluent">{t.fluent}</span>
        </li>
        <li>
          <span data-key="langSpan">{t.langSpan}</span> 
          <span class="lang-badge inter" data-key="inter">{t.inter}</span>
        </li>
        <li>
          <span data-key="langGer">{t.langGer}</span> 
          <span class="lang-badge basic" data-key="basic">{t.basic}</span>
        </li>
      </ul>
    </div>
  </div>
</aside>