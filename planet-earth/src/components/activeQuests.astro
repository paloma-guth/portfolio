---
const { t = {} } = Astro.props; 
---
<section id="active-quests">
  <h2 data-key="activeQuests">{t.activeQuests}</h2>
  
  <div class="quest-list">
    <a href="https://github.com/paloma-guth/StardewValley-crops" target="_blank" class="quest-card-link">
      <article class="quest-card active">
        <div class="pulse-indicator"></div> 
        <h3 data-key="stardewTitle">{t.stardewTitle}</h3>
        <p data-key="stardewDesc">{t.stardewDesc}</p>
        
        <div class="loot-tags">
          <span class="tag">Python</span>
          <span class="tag" data-key="tagScraping">{t.tagScraping}</span>
          <span class="tag">JSON</span>
          <span class="tag" data-key="tagCleaning">{t.tagCleaning}</span>
        </div>
      </article>
    </a>

    <a href="https://github.com/paloma-guth/GuildSystem" target="_blank" class="quest-card-link">
      <article class="quest-card active">
        <div class="pulse-indicator"></div>
        <h3 data-key="sqlTitle">{t.sqlTitle}</h3>
        <p data-key="sqlDesc">{t.sqlDesc}</p>
        
        <div class="loot-tags">
          <span class="tag" data-key="tagSchema">{t.tagSchema}</span>
          <span class="tag" data-key="tagRelational">{t.tagRelational}</span>
          <span class="tag" data-key="tagJoins">{t.tagJoins}</span>
          <span class="tag" data-key="tagIntegrity">{t.tagIntegrity}</span>
        </div>
      </article>
    </a>

    <div class="quest-footer">
      <a href="/portfolio/quests/" class="quest-log-btn">
        <i class="fa-solid fa-book-journal-whills"></i> 
        <span data-key="seeQuestLog">{t.seeQuestLog}</span>
      </a>
    </div>
  </div>
</section>