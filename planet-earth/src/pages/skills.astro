---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import { content } from '../components/languages';
import '../styles/skillsBook.css';

const t = content.EN;

// Pre-group for the initial EN server-side render
const groupedSkills = t.technicalSkills.reduce((acc, skill) => {
  if (!acc[skill.lvl]) acc[skill.lvl] = [];
  acc[skill.lvl].push(skill.name);
  return acc;
}, {});
const sortedLevels = Object.keys(groupedSkills).sort((a, b) => Number(a) - Number(b));
---
<Layout title="Skills | Paloma Guth">
  <Header />

  <main class="skills-page">
    <header class="skills-header">
      <a href="/" class="back-link" data-key="back">{t.back}</a>
      <h1 data-key="spellbookTitle">{t.spellbookTitle}</h1>
      <p class="disclaimer" data-key="levelDisclaimer">{t.levelDisclaimer}</p>
    </header>

    <section class="intro-row">
      <article class="skill-card cantrip-main">
        <h2 class="section-label" data-key="cantripTitle">{t.cantripTitle}</h2>
        <ul class="cantrip-list" data-list="cantrips">
          {t.cantrips.map(name => <li>{name}</li>)}
        </ul>
      </article>

      <div class="flavor-text">
        <blockquote data-key="flavorQuote">{t.flavorQuote}</blockquote>
        <cite data-key="flavorAuthor">{t.flavorAuthor}</cite>
      </div>
    </section>

    <div class="divider"></div>

    <section class="skills-grid">
      {sortedLevels.map((lvl) => {
        const isLocked = Number(lvl) >= 8;
        return (
          <article class={`skill-card lvl-group ${isLocked ? 'locked' : ''}`}>
            <div class="lvl-badge">
              <span>{lvl}</span>
              {isLocked && <i class="fa-solid fa-lock lock-icon"></i>}
            </div>
            
            <h3 class="lvl-title" data-lvl={lvl} data-locked={isLocked}>
              {isLocked ? t.futureQuest : t.lvlMastery.replace('{n}', lvl)}
            </h3>
            
            <ul class="mastery-list" data-lvl-list={lvl}>
              {groupedSkills[lvl].map(skillName => (
                <li>{skillName}</li>
              ))}
            </ul>
          </article>
        );
      })}
    </section>
  </main>
</Layout>

<script define:vars={{ content }}>
  window.addEventListener('langChange', (e) => {
    const lang = e.detail;
    const t = content[lang];

    // Update simple text
    document.querySelectorAll('[data-key]').forEach(el => {
      const key = el.getAttribute('data-key');
      if (t[key]) el.innerText = t[key];
    });

    // Update Cantrips list
    const cantripList = document.querySelector('[data-list="cantrips"]');
    if (cantripList) {
      cantripList.innerHTML = t.cantrips.map(c => `<li>${c}</li>`).join('');
    }

    // Update Technical Skills lists
    const grouped = t.technicalSkills.reduce((acc, skill) => {
      if (!acc[skill.lvl]) acc[skill.lvl] = [];
      acc[skill.lvl].push(skill.name);
      return acc;
    }, {});

    document.querySelectorAll('[data-lvl-list]').forEach(ul => {
      const lvl = ul.getAttribute('data-lvl-list');
      if (grouped[lvl]) {
        ul.innerHTML = grouped[lvl].map(s => `<li>${s}</li>`).join('');
      }
    });

    // Update level titles (e.g., "Level 7 Masteries")
    document.querySelectorAll('.lvl-title').forEach(h3 => {
        const lvl = h3.getAttribute('data-lvl');
        const isLocked = h3.getAttribute('data-locked') === 'true';
        h3.innerText = isLocked ? t.futureQuest : t.lvlMastery.replace('{n}', lvl);
    });
  });
</script>