---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Education from '../components/education.astro';
import Experience from '../components/experience.astro';
import ActiveQuests from '../components/activeQuests.astro';
import Inventory from '../components/inventory.astro';
import Sidebar from '../components/Sidebar.astro';
import '../styles/global.css'; 
import '../styles/sidebar.css';
import '../styles/animations.css';
import { content } from '../components/languages';

const t = content.EN;
---

<Layout title="Paloma | Data Sorcerer">
  <Header />

  <main class="portfolio-grid">
    <div class="main-content">
      <section class="hero-section">
        <h1 data-key="heroTitle">{content.EN.heroTitle}</h1>
        <p class="subtitle" data-key="heroSub">{content.EN.heroSub}</p>
        <div class="divider"></div>
        <div class="bio-section">
          <p class="sidebar-bio" data-key="bio">{t.bio}</p>
          
          <div class="extra-section">
            <span class="extra-label" data-key="extraTitle">{t.extraTitle}</span>
            <p class="extra-text" data-key="extraBio">{t.extraBio}</p>
          </div>
        </div>
      </section>

      <Education t={t} />

      <ActiveQuests t={t} />

      <Experience t={t} />

      <Inventory t={t} />      
    </div>

    <Sidebar content={content} lang="EN" />

    <div class="main-wrapper">
      <aside class="sidebar">
        </aside>

      <main class="content">
        </main>
    </div>
    
  </main>
</Layout>

<script define:vars={{ content }}>
  const translate = (l) => {
    const t = content[l];
    document.querySelectorAll('[data-key]').forEach(el => {
      const key = el.getAttribute('data-key');
      if (t[key]) el.innerText = t[key];
    });
  };

  // Run immediately
  const startLang = localStorage.getItem('lang') || 'EN';
  if (startLang !== 'EN') {
    // If it's not English, we need to hide the body momentarily or 
    // run the translation so fast it's invisible.
    translate(startLang);
  }

  window.addEventListener('langChange', (e) => translate(e.detail));
</script>

