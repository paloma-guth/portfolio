---
const { t } = Astro.props;
---
<section id="experience">
  <h2 data-key="experience">{t.experience}</h2>
  
  <div class="timeline">
    <div class="timeline-item">
      <div class="time-dot"></div>
      <h3 data-key="job1Title">{t.job1Title}</h3>
      <p class="meta" data-key="job1Place">{t.job1Place}</p>
      <div class="quest-details">
        <p data-key="job1Desc">{t.job1Desc}</p>
      </div>
      <div class="loot-tags">
        <span class="tag">Python</span>
        <span class="tag">Debian Linux</span>
        <span class="tag">Raspberry Pi</span>
        <span class="tag">Kanban</span>
      </div>
    </div>

    <div class="timeline-item">
      <div class="time-dot"></div>
      <h3 data-key="job2Title">{t.job2Title}</h3>
      <p class="meta" data-key="job2Place">{t.job2Place}</p>
      <div class="quest-details">
        <p data-key="job2Desc">{t.job2Desc}</p>
      </div>
      <div class="loot-tags">
        <span class="tag" data-key="tagDoc">{t.tagDoc}</span>
        <span class="tag">Hardware Troubleshooting</span>
        <span class="tag">Inventory Management</span>
      </div>
    </div>

    <div id="extra-experience" class="hidden-experience">
      <div class="timeline-item">
        <div class="time-dot"></div>
        <h3 data-key="taTitle">{t.taTitle}</h3>
        <p class="meta" data-key="taPlace">{t.taPlace}</p>
        <div class="quest-details">
          <p data-key="taDesc">{t.taDesc}</p>
        </div>
        <div class="loot-tags">
          <span class="tag">Logic Gates</span>
          <span class="tag">Assembly</span>
          <span class="tag" data-key="tagDebug">{t.tagDebug}</span>
        </div>
      </div>
    </div>

    <button id="exp-toggle-btn" class="archive-toggle">
      <span class="toggle-text" data-key="viewMore">{t.viewMore || "View More History"}</span>
      <i class="fa-solid fa-chevron-down"></i>
    </button>
  </div>
</section>

<script>
  const btn = document.getElementById('exp-toggle-btn');
  const container = document.getElementById('extra-experience');
  
  btn?.addEventListener('click', () => {
    const isActive = container?.classList.toggle('active');
    const icon = btn.querySelector('i');
    
    if (icon) {
      icon.style.transform = isActive ? 'rotate(180deg)' : 'rotate(0deg)';
    }
  });
</script>