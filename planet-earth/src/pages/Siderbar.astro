---
import '../styles/sidebar.css';
const { content, lang = "EN" } = Astro.props;
const t = content[lang];
---

<aside class="sidebar">
  <div class="profile-card">
    <div class="photo-placeholder"></div>
    <h2 class="character-name">Paloma Guth</h2>
    <p class="character-class">Data Paladin | <span data-key="lvl">{t.lvl}</span> 15</p>

    <div class="social-links">
      <a href="https://github.com/paloma-guth" target="_blank" aria-label="GitHub"><i class="fa-brands fa-github"></i></a>
      <a href="https://www.linkedin.com/in/paloma-guth-..." target="_blank" aria-label="LinkedIn"><i class="fa-brands fa-linkedin"></i></a>
    </div>

    <div class="attributes-section">
      <h4 class="attribute-title"></i> Core Attributes</h4>
      <ul class="stats-list">
        <li><span>System Design (INT)</span> <span class="stat-value">18</span></li>
        <li><span>Documentation (CHA)</span> <span class="stat-value">15</span></li>
        <li><span>Escale (DEX)</span> <span class="stat-value">12</span></li>
        <li><span>Error handling (WIS)</span> <span class="stat-value">12</span></li>
      </ul>
    </div>

    <div class="skills-section">
      <h4 class="attribute-title"></i> <span data-key="skills">{t.skills}</span></h4>
      <div class="skill-item">
        <span class="skill-name">Python</span>
        <div class="spell-levels">
          <span class="orb filled"></span><span class="orb filled"></span><span class="orb filled"></span><span class="orb filled"></span><span class="orb"></span>
        </div>
      </div>
      <div class="skill-item">
        <span class="skill-name">Linux</span>
        <div class="spell-levels">
          <span class="orb filled"></span><span class="orb filled"></span><span class="orb filled"></span><span class="orb filled"></span><span class="orb"></span>
        </div>
      </div>
      <div class="skill-item">
        <span class="skill-name">C</span>
        <div class="spell-levels">
          <span class="orb filled"></span><span class="orb filled"></span><span class="orb filled"></span><span class="orb filled"></span><span class="orb"></span>
        </div>
      </div>
      <a href="/skills" class="spellbook-btn">
        <i class="fa-solid fa-book-sparkles"></i> Full Spellbook
      </a>
    </div>

    <div class="attributes-section">
      <h4 class="attribute-title"><i class="fa-solid fa-feather-pointed"></i> Known Tongues</h4>
      <ul class="language-list">
        <li><span>Portuguese</span> <span class="lang-badge native">Native</span></li>
        <li><span>English</span> <span class="lang-badge fluent">Fluent</span></li>
        <li><span>Spanish</span> <span class="lang-badge inter">Intermediary</span></li>
        <li><span>German</span> <span class="lang-badge basic">Basic</span></li>
      </ul>
    </div>
  </div>
</aside>